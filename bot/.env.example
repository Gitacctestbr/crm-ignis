# ============================================================
# bot/.env — copiar pra bot/.env e preencher na VPS.
# NUNCA versionar este arquivo com valores reais.
# Permissões: chmod 600 bot/.env
# ============================================================

# Token do bot (criado via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# Anthropic API (mesma usada pelo print_processor.py legacy — pode reutilizar)
ANTHROPIC_API_KEY=

# Supabase
# SUPABASE_URL: pega em Project Settings → API → Project URL
# SUPABASE_SERVICE_ROLE_KEY: pega em Project Settings → API → service_role secret
#   ⚠️ Esta key BYPASSA RLS — nunca exponha em frontend ou em arquivo público.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Modelos (defaults: Haiku 4.5 primário, Sonnet 4.6 fallback)
MODEL_PRIMARY=claude-haiku-4-5-20251001
MODEL_FALLBACK=claude-sonnet-4-6

# Concorrência (10 clientes — não precisa tunar)
MAX_CONCURRENT_OCR_GLOBAL=20
MAX_CONCURRENT_OCR_PER_CHAT=3

# Logging
LOG_LEVEL=INFO
